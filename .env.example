# ===========================================
# Elise - Environment Variables
# ===========================================
# Copy this file to .env.local for local development

# -----------------------------------------
# CONVEX CONFIGURATION
# -----------------------------------------
# Staging: https://rare-blackbird-695.convex.cloud
# Production: https://agile-shrimp-456.convex.cloud
NEXT_PUBLIC_CONVEX_URL=

# Convex deployment name for `bunx convex dev` (local development only)
CONVEX_DEPLOYMENT=

# Deploy key for CI/CD (Netlify uses this)
# Generate at: https://dashboard.convex.dev -> Settings -> Deploy Keys
# DO NOT commit this key - set it in Netlify environment variables
# CONVEX_DEPLOY_KEY=

# -----------------------------------------
# OPTIONAL: EXTERNAL APIS
# -----------------------------------------
# GIPHY API (for GIF picker in reviews)
# Get key at: https://developers.giphy.com
# NEXT_PUBLIC_GIPHY_API_KEY=
